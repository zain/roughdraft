{
  "name": "roughdraft",
  "version": "0.1.0",
  "description": "An infinite canvas for writing",
  "license": "MIT",
  "author": "Nathan Baschez",
  "bin": {
    "roughdraft": "./packages/server/bin/roughdraft.mjs"
  },
  "scripts": {
    "setup": "./scripts/setup.sh",
    "start": "./scripts/run.sh",
    "dev": "node scripts/dev.mjs",
    "dev:web": "VITE_PREVIEW_WEB=1 pnpm --filter @roughdraft/app dev",
    "lint": "biome check . --assist-enabled=false",
    "lint:fix": "biome check --write . --assist-enabled=false",
    "format": "biome format --write .",
    "test": "pnpm --filter @roughdraft/app test && pnpm --filter @roughdraft/server test",
    "check": "pnpm lint && pnpm test && pnpm build",
    "build": "pnpm --filter @roughdraft/app build && pnpm --filter @roughdraft/server build",
    "preview": "node packages/server/bin/roughdraft.mjs"
  },
  "files": [
    "packages/app/dist",
    "packages/server/dist",
    "packages/server/bin"
  ],
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
